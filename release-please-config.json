{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "package-name": "aws-console-switcher",
      "release-type": "node",
      "extra-files": [
        {
          "type": "json",
          "path": "packages/shared/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "packages/extension/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "packages/native-host/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "package-lock.json",
          "jsonpath": "$.packages['packages/shared'].version"
        },
        {
          "type": "json",
          "path": "package-lock.json",
          "jsonpath": "$.packages['packages/extension'].version"
        },
        {
          "type": "json",
          "path": "package-lock.json",
          "jsonpath": "$.packages['packages/native-host'].version"
        },
        {
          "type": "generic",
          "path": "packages/extension/manifest.config.ts"
        }
      ]
    }
  }
}
